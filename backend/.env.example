# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

#Get it from https://platform.claude.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Which transcription backend to use.
# Options: whisper_api | local_whisper
# Swap this value to change providers — no code changes required.
TRANSCRIPTION_PROVIDER=whisper_api
FALLBACK_TRANSCRIPTION_PROVIDER=local_whisper

# Optional: full path to FFmpeg bin/ dir if ffmpeg is not on your PATH (common on Windows)
# FFMPEG_BIN=C:\path\to\ffmpeg\bin

CORS_ORIGINS=http://localhost:5173
# Comma-separated allowed CORS origins. Override in production with your actual domain.
# CORS_ORIGINS=https://yourdomain.com
